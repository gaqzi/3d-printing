#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

# Ensure bd (beads) is installed
if ! command -v bd >/dev/null 2>&1; then
  echo "error: bd (beads) is required but not installed." >&2
  echo "  brew install beads" >&2
  exit 1
fi

# Ensure beads hooks are wired up
bd hooks install --beads >/dev/null 2>&1 || true

# Wire script/hooks/pre-commit into beads hook
hook=".beads/hooks/pre-commit"
marker="script/hooks/pre-commit"
if ! grep -q "$marker" "$hook" 2>/dev/null; then
  cat >> "$hook" <<'HOOK'

# --- Project hooks ---
"$(git rev-parse --show-toplevel)/script/hooks/pre-commit"
HOOK
fi

while IFS=' ' read -r repo ref target; do
  # Skip comments and blank lines
  [[ -z "$repo" || "$repo" == \#* ]] && continue

  echo "==> $target @ ${ref:0:12}"

  if [ -d "$target/.git" ]; then
    git -C "$target" fetch origin
  else
    rm -rf "$target"
    mkdir -p "$(dirname "$target")"
    git clone -q "$repo" "$target"
  fi

  git -C "$target" checkout -q "$ref"
done < dependencies.txt

echo "Done."
