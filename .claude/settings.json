{
  "permissions": {
    "allow": [
      "Bash(bd:*)",
      "Bash(script/build:*)",
      "Bash(/Applications/OpenSCAD.app/Contents/MacOS/OpenSCAD:*)"
    ],
    "deny": [
      "Bash(git commit:*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "excludedCommands": [
      "bd",
      "script/build",
      "/Applications/OpenSCAD.app/Contents/MacOS/OpenSCAD"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }

}
